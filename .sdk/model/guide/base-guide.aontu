# Guide

guide: {
  metrics: count: entity: 1
  metrics: count: path: 2
  metrics: count: method: 2

  entity: dataset: {
    path: "/opendata/": {
      op: list: method: *GET
    }
    path: "/opendata/dataset/{datasetId}": {
      rename: param: "datasetId": *"id"
      op: load: method: *GET
    }
  }

}